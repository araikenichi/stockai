{
  "name": "stockai",
  "version": "2.0.11",
  "description": "StockAI - AI stock analysis desktop assistant",
  "main": "main.js",
  "author": "StockAI Contributors",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run dist:arm64 && npm run dist:x64",
    "dist:arm64": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64",
    "dist:x64": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --x64",
    "check": "node --check main.js && node --check app.js && node --check preload.js"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.0",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.stockai.desktop",
    "productName": "StockAI",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "ui.html",
      "package.json",
      "README.md",
      "DISCLAIMER.md",
      "PRIVACY.md",
      "SECURITY.md",
      "LICENSE"
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "protocols": [
      {
        "name": "StockAI",
        "schemes": [
          "stockai"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "araikenichi",
      "repo": "stockai"
    },
    "afterPack": "scripts/fix-mac-pack.js"
  }
}
